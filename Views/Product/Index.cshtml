@model IEnumerable<BIsm2.Models.Product>
@{
    var username = ViewBag.Username as string;
}
<style>
    .dropdown {
        border: 1px solid #ccc;
        max-height: 150px;
        overflow-y: auto;
        position: absolute;
        background: white;
        list-style: none;
        padding: 0;
        margin: 0;
        width: 200px;
    }
    .dropdown li {
        padding: 5px;
        cursor: pointer;
    }
    .dropdown li:hover {
        background: #eee;
    }
</style>
<h1>this is indexpage</h1>
<h2><a asp-controller="Product" asp-action="SellersPg">become a Seller</a></h2>

<a asp-controller="Product" asp-action="Cart">
    🛒 Cart (<span id="cartCount">@ViewBag.CartCount</span>)
</a>
@if (TempData["Message"] != null)
{
    <div id="message">@TempData["Message"]</div>
    <script>
        setTimeout(() => document.getElementById("message").style.display = "none", 3000);
    </script>
}


<h2>Search Products</h2>

<form asp-action="Search" method="get" class="search-form">
    <input type="text" id="searchBox" name="query" placeholder="Search products..." autocomplete="off" />
    <button type="submit">Search</button>
    <ul id="suggestions" class="dropdown"></ul>
</form>



<h2>Products</h2>
@if (!string.IsNullOrEmpty(username))
{
    <h2>Hello @username!</h2>
}

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Price</th>
            <th>Media</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td>@product.Name</td>
                <td>@product.Price</td>
                <td>
                    @if (product.Media != null && product.Media.Any())
                    {
                        var firstMedia = product.Media.First();

                        if (firstMedia.Type == MediaType.Image)
                        {
                            <img src="data:@firstMedia.ContentType;base64,@Convert.ToBase64String(firstMedia.FileData)"
                                 style="max-width:150px;" />
                        }
                        else if (firstMedia.Type == MediaType.Video)
                        {
                            <video controls style="max-width:200px;">
                                <source src="data:@firstMedia.ContentType;base64,@Convert.ToBase64String(firstMedia.FileData)"
                                        type="@firstMedia.ContentType" />
                            </video>
                        }
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@product.Id">Details</a>
                </td>
                <td>
                    <form asp-action="AddToCart" asp-controller="Product" method="post">
                        <input type="hidden" name="productId" value="@product.Id" />
                        <button type="submit">Add to Cart</button>
                    </form>
                </td>
                <td>
                    <a asp-controller="Product" asp-action="BuyNow" asp-route-id="@product.Id" class="btn btn-primary">
                        Buy Now
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>


@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.0/jquery-ui.min.js"></script>
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.0/themes/base/jquery-ui.css" />

    <script>
        $("#searchBox").autocomplete({
        source: function (request, response) {
        $.ajax({
        url: '@Url.Action("Autocomplete", "Product")',
        data: { term: request.term },
        success: function (data) {
        response(data);
        }
        });
        },
        minLength: 2
        });

        const searchBox = document.getElementById('searchBox');
        const suggestions = document.getElementById('suggestions');

        searchBox.addEventListener('input', async () => {
        const term = searchBox.value;
        if (term.length < 2) {
        suggestions.innerHTML = '';
        return;
        }

        const response = await fetch(`/Product/Autocomplete?term=${encodeURIComponent(term)}`);
        const data = await response.json();

        suggestions.innerHTML = '';
        data.forEach(item => {
        const li = document.createElement('li');
        li.textContent = item;
        li.onclick = () => {
        searchBox.value = item;
        suggestions.innerHTML = '';
        document.querySelector('.search-form').submit();
        };
        suggestions.appendChild(li);
        });
        });
    </script>
}
