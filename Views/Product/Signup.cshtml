@using BIsm2.ViewModels
@model SignupViewModel
@Html.ValidationSummary(excludePropertyErrors: true)
<form asp-controller="Product" asp-action="Signup" method="post">
    <input asp-for="UserName" placeholder="UserName">
        <span asp-validation-for="UserName"></span>
        <br>
        <input asp-for="Email" placeholder="Email" type="email">
            <span asp-validation-for="Email"></span>
            <br>
            <input asp-for="Password" placeholder="Password" type="password">
                <span asp-validation-for="Password"></span>
                <br>
                <input asp-for="ConfirmPassword" placeholder="ConfirmPassword" type="password">
                    <span asp-validation-for="ConfirmPassword"></span>
                    <br>
                    <button type="submit">Sign up</button>
                </form>